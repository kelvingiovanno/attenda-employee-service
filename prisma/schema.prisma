generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  SUSPENDED
}

model Employee {
  id          String   @id @default(uuid())
  fullname     String
  email        String   @unique
  department   String
  position     String

  hireDate     DateTime?
  status       EmployeeStatus @default(ACTIVE)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
}
